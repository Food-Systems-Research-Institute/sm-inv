@article{mahmood2024EffectsCOVID19Agriculture,
  title = {The Effects of {{COVID-19}} on Agriculture Supply Chain, Food Security, and Environment: A Review},
  shorttitle = {The Effects of {{COVID-19}} on Agriculture Supply Chain, Food Security, and Environment},
  author = {Mahmood, Haider and Furqan, Maham and Meraj, Gowhar and Hassan, Muhammad Shahid},
  year = 2024,
