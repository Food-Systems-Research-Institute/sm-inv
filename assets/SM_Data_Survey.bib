@article{amiri2020FoodSystemSustainability,
  title = {Food System Sustainability Investigation Using System Dynamics Approach},
  author = {Amiri, Alireza and Mehrjerdi, Yahia Zare and Jalalimanesh, Ammar and Sadegheih, Ahmad},
  year = 2020,
  month = dec,
  journal = {Journal of Cleaner Production},
  volume = {277},
  pages = {124040},
  issn = {0959-6526},
  doi = {10.1016/j.jclepro.2020.124040},
  urldate = {2025-05-08},
  abstract = {Food system sustainability is an important problem for feeding the current generation such that it does not jeopardize the feeding of the next generations. In this research, we investigate the effective factors of the wheat production system and analyze them using a system dynamics approach. The causal loop diagrams of the relationship between these factors and wheat production are analyzed based on their past behaviors and related research. Then, we simulate the problem based on the flow diagram, and after validating the developed model, we propose several scenarios and analyze and discuss their impact on the different dimensions of wheat production sustainability. Due to the high sensitivity of wheat production to rainfall fluctuations and technology levels, more appropriate planning and investment should be made for the better and more efficient use of these two resources.},
  keywords = {Food system sustainability,System dynamics,Wheat production},
  file = {C\:\\Users\\cdonov12\\Zotero\\storage\\9FZHV3QS\\Amiri et al. - 2020 - Food system sustainability investigation using system dynamics approach.pdf;C\:\\Users\\cdonov12\\Zotero\\storage\\D5ZLIU5K\\S0959652620340853.html}
}

