@misc{basharat2024RoleDataGovernance,
  type = {{{SSRN Scholarly Paper}}},
  title = {The Role of Data Governance in Addressing Potential Risks Associated with Agricultural Data Exchanges: {{A}} Systematic Literature Review},
  shorttitle = {The Role of Data Governance in Addressing Potential Risks Associated with Agricultural Data Exchanges},
  author = {Basharat, Ali and Bewong, Michael and {Krivokapic-skoko}, Branka and Ip, Ryan H. L. and Lewis, Clifford and {Al-Saggaf}, Yeslam and Islam, Md Zahidul},
  year = 2024,
