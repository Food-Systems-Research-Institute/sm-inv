@article{keegan2024ExploringResilienceConcepts,
  title = {Exploring Resilience Concepts and Strategies within Regional Food Systems: A Systematic Literature Review},
  shorttitle = {Exploring Resilience Concepts and Strategies within Regional Food Systems},
