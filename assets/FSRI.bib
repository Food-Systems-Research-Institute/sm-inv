@article{tomaszuk2020RDFKnowledgeRepresentation,
  title = {{{RDF}} 1.1: {{Knowledge Representation}} and {{Data Integration Language}} for the {{Web}}},
  shorttitle = {{{RDF}} 1.1},
  author = {Tomaszuk, Dominik and {Hyland-Wood}, David},
  year = 2020,
