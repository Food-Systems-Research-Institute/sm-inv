  keywords = {Dairy,Immigrant farmworker,Latino,Latino and Latina Sociology,Light Stress,Migrant farmworker,Social Work and Migration,Social Work Research,Sociology of Work,Stress,Stress fibres,Vermont},
  file = {C:\Users\cdonov12\Zotero\storage\CFVCW5SZ\Baker et al. - 2021 - Dairy is Different Latino Dairy Worker Stress in Vermont.pdf}
}

