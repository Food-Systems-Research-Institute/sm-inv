@article{orousannou2023IntegratingSocialPerspective,
  title = {Integrating the Social Perspective into the Sustainability Assessment of Agri-Food Systems: {{A}} Review of Indicators},
  shorttitle = {Integrating the Social Perspective into the Sustainability Assessment of Agri-Food Systems},
  author = {Orou Sannou, Ramoudane and Kirschke, Sabrina and G{\"u}nther, Edeltraud},
