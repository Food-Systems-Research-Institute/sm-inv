  journal = {Food Security},
  volume = {14},
  number = {1},
  pages = {165--183},
  issn = {1876-4525},
  doi = {10.1007/s12571-021-01189-1},
  urldate = {2025-09-30},
  abstract = {The COVID-19 pandemic significantly increased food insecurity despite emergency legislation that put more resources into food assistance programs, increased unemployment benefits, and provided stimulus payments. We conducted a survey in the US on food insecurity among low-income Americans during the early months of the pandemic. While we cannot estimate causal effects, we are able to show important associations between food insecurity and nutritional and economic assistance that highlight the need to ensure that those newly at risk for food insecurity are able to connect to resources. For example, our results indicate that those who lost jobs due to the pandemic reported the highest level of food insecurity and also the lowest engagement with food assistance programs. The SNAP expansion appears to be important only among groups with higher levels of income stability including non-minority households and those not experiencing a job loss. Thus, the SNAP expansion may not have had a meaningful impact on those most at risk for food insecurity. Finally, our data highlight the importance of school meal programs during normal times. Those who took advantage of school meals before the outbreak are more likely to have experienced food insecurity during the pandemic-related school closures.},
  langid = {english},
  keywords = {C31,COVID-19 pandemic,Food insecurity,I14,Low-income,Q18,Racial disparity},
  file = {C:\Users\cdonov12\Zotero\storage\DTDINRE6\Fang et al. - 2022 - Food insecurity during the COVID-19 pandemic evidence from a survey of low-income Americans.pdf}
}

@article{fanzo2021ViewpointRigorousMonitoring,
  title = {Viewpoint: {{Rigorous}} Monitoring Is Necessary to Guide Food System Transformation in the Countdown to the 2030 Global Goals},
  shorttitle = {Viewpoint},
  author = {Fanzo, Jessica and Haddad, Lawrence and Schneider, Kate R. and B{\'e}n{\'e}, Christophe and Covic, Namukolo M. and Guarin, Alejandro and Herforth, Anna W. and Herrero, Mario and Sumaila, U. Rashid and Aburto, Nancy J. and {Amuyunzu-Nyamongo}, Mary and Barquera, Simon and Battersby, Jane and Beal, Ty and Bizzotto Molina, Paulina and Brusset, Emery and Cafiero, Carlo and Campeau, Christine and Caron, Patrick and Cattaneo, Andrea and Conforti, Piero and Davis, Claire and DeClerck, Fabrice A. J. and Elouafi, Ismahane and Fabi, Carola and Gephart, Jessica A. and Golden, Christopher D. and Hendriks, Sheryl L. and Huang, Jikun and Laar, Amos and Lal, Rattan and Lidder, Preetmoninder and Loken, Brent and Marshall, Quinn and Masuda, Yuta J. and McLaren, Rebecca and Neufeld, Lynnette M. and Nordhagen, Stella and Remans, Roseline and Resnick, Danielle and Silverberg, Marissa and Torero Cullen, Maximo and Tubiello, Francesco N. and {Vivero-Pol}, Jose-Luis and Wei, Shijin and Rosero Moncayo, Jose},
  year = 2021,
  month = oct,
  journal = {Food Policy},
  volume = {104},
  pages = {102163},
  issn = {0306-9192},
  doi = {10.1016/j.foodpol.2021.102163},
  urldate = {2024-09-18},
  abstract = {Food systems that support healthy diets in sustainable, resilient, just, and equitable ways can engender progress in eradicating poverty and malnutrition; protecting human rights; and restoring natural resources. Food system activities have contributed to great gains for humanity but have also led to significant challenges, including hunger, poor diet quality, inequity, and threats to nature. While it is recognized that food systems are central to multiple global commitments and goals, including the Sustainable Development Goals, current trajectories are not aligned to meet these objectives. As mounting crises further stress food systems, the consequences of inaction are clear. The goal of food system transformation is to generate a future where all people have access to healthy diets, which are produced in sustainable and resilient ways that restore nature and deliver just, equitable livelihoods. A rigorous, science-based monitoring framework can support evidence-based policymaking and the work of those who hold key actors accountable in this transformation process. Monitoring can illustrate current performance, facilitate comparisons across geographies and over time, and track progress. We propose a framework centered around five thematic areas related to (1) diets, nutrition, and health; (2) environment and climate; and (3) livelihoods, poverty, and equity; (4) governance; and (5) resilience and sustainability. We hope to call attention to the need to monitor food systems globally to inform decisions and support accountability for better governance of food systems as part of the transformation process. Transformation is possible in the next decade, but rigorous evidence is needed in the countdown to the 2030 SDG global goals.},
  keywords = {Food system governance,Food system resilience,Healthy diets,Sustainable development goals,Sustainable food systems,Sustainable livelihoods},
  file = {C\:\\Users\\cdonov12\\Zotero\\storage\\RIHDRTS8\\Fanzo et al. - 2021 - Viewpoint Rigorous monitoring is necessary to gui.pdf;C\:\\Users\\cdonov12\\Zotero\\storage\\3UMY76QE\\S0306919221001433.html}
}

