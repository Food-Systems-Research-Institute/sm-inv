@article{duttaDecolonizingOpenScience2021,
  title = {Decolonizing {{Open Science}}: {{Southern Interventions}}},
  shorttitle = {Decolonizing {{Open Science}}},
  author = {Dutta, Mohan and Ramasubramanian, Srividya and Barrett, Mereana and Elers, Christine and Sarwatay, Devina and Raghunath, Preeti and Kaur, Satveer and Dutta, Debalina and Jayan, Pooja and Rahman, Mahbubur and Tallam, Edwin and Roy, Sudeshna and Falnikar, Ashwini and Johnson, Gayle Moana and Mandal, Indranil and Dutta, Uttaran and Basnyat, Iccha and Soriano, Cheryll and Pavarala, Vinod and Sreekumar, T T and Ganesh, Shiv and Pandi, Asha Rathina and Zapata, Dazzelyn},
