@article{jianDatabaseGlobalSoil2020,
  title = {A Database for Global Soil Health Assessment},
  author = {Jian, Jinshi and Du, Xuan and Stewart, Ryan D.},
  year = 2020,
  month = jan,
  journal = {Scientific Data},
