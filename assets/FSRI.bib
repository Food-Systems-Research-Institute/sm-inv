@article{schreefel2024HowMonitorSuccess,
  title = {How to Monitor the `Success' of Agricultural Sustainability: {{A}} Perspective},
  shorttitle = {How to Monitor the `Success' of Agricultural Sustainability},
  author = {Schreefel, L. and Creamer, R. E. and {van Zanten}, H. H. E. and {de Olde}, E. M. and Koppelm{\"a}ki, K. and Debernardini, M. and {de Boer}, I. J. M. and Schulte, R. P. O.},
  year = 2024,
  month = dec,
  journal = {Global Food Security},
  volume = {43},
  pages = {100810},
  issn = {2211-9124},
  doi = {10.1016/j.gfs.2024.100810},
  urldate = {2025-08-22},
  abstract = {Global food security is threatened by widespread degradation of agricultural land and associated loss of ecosystem services. In response, farming approaches such as regenerative agriculture are heralded by industries and governments as mainstream solutions to keep the global food system within planetary boundaries. The low level of consensus on science-based approaches to the monitoring and verification of the efficacy of such solutions, however, has left many initiatives vulnerable to allegations of greenwashing. In this paper, we present a comprehensive perspective on the role of indicators for monitoring agricultural systems. We subsequently propose a flexible yet coherent framework for the transparent, time and context-sensitive selection of indicators for monitoring the extent to which sustainability initiatives contribute to their goals.},
