@article{zia2016CoupledImpactsClimate,
  title = {Coupled Impacts of Climate and Land Use Change across a River--Lake Continuum: Insights from an Integrated Assessment Model of {{Lake Champlain}}'s {{Missisquoi Basin}}, 2000--2040},
  shorttitle = {Coupled Impacts of Climate and Land Use Change across a River--Lake Continuum},
  author = {Zia, Asim and Bomblies, Arne and Schroth, Andrew W and Koliba, Christopher and Isles, Peter D F and Tsai, Yushiou and Mohammed, Ibrahim N and Bucini, Gabriela and Clemins, Patrick J and Turnbull, Scott and Rodgers, Morgan and Hamed, Ahmed and Beckage, Brian and Winter, Jonathan and Adair, Carol and Galford, Gillian L and Rizzo, Donna and Van Houten, Judith},
